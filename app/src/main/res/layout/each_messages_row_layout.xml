<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="data"
            type="com.orbis.orbis.models.message.ConversationModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/comment_cl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/user_icon_iv"
                android:layout_width="53dp"
                android:layout_height="53dp"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="@dimen/margin_top_16dp"
                android:contentDescription="@string/image_description"
                android:src="@drawable/ic_user"
                app:civ_border_width="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/user_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_12dp"
            android:fontFamily="@font/roboto_bold"
            android:text="@{data.sender.displayName}"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_16sp"
            app:layout_constraintStart_toEndOf="@id/user_icon_iv"
            app:layout_constraintTop_toTopOf="@+id/user_icon_iv" />


        <TextView
            android:id="@+id/have_new_tv"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="@dimen/margin_end_32dp"
            android:fontFamily="@font/poppins_regular"
            android:background="@drawable/bg_rounded_black"
            android:textColor="@color/post_color"
            android:textSize="@dimen/text_size_11sp"
            app:layout_constraintBottom_toBottomOf="@+id/user_name_tv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/user_name_tv" />

        <TextView
            android:id="@+id/message_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/roboto_regular"
            android:textColor="@color/post_color"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintEnd_toStartOf="@+id/have_new_tv"
            app:layout_constraintStart_toStartOf="@+id/user_name_tv"
            app:layout_constraintTop_toBottomOf="@+id/user_name_tv" />


    </androidx.constraintlayout.widget.ConstraintLayout>


    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="1.5dp"
        android:layout_marginTop="@dimen/margin_bottom_16dp"
        android:background="@color/line_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/comment_cl" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>