<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="loading"
            type="Boolean" />

        <variable
            name="data"
            type="com.orbis.orbis.models.auth.UserInfo" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout

        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <RelativeLayout
                    android:id="@+id/service_terms_rl"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/bg_setting_btn"
                    app:layout_constraintEnd_toEndOf="@+id/termsOfService"
                    app:layout_constraintStart_toStartOf="@+id/termsOfService"
                    app:layout_constraintTop_toBottomOf="@+id/termsOfService">

                    <TextView
                        android:id="@+id/service_terms_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/textView_privacy_policy"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/termsOfService"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/bg_setting_btn"
                    app:layout_constraintEnd_toEndOf="@+id/invite_friends_rl"
                    app:layout_constraintStart_toStartOf="@+id/invite_friends_rl"
                    app:layout_constraintTop_toBottomOf="@+id/invite_friends_rl">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/terms_of_service"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/loader18"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerInParent="true"
                    android:layout_centerVertical="false"
                    android:elevation="8dp"
                    android:visibility="@{loading ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:lottie_autoPlay="true"
                    app:lottie_fileName="loader.json"
                    app:lottie_loop="true" />

                <TextView
                    android:id="@+id/saveChange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:fontFamily="@font/roboto_black"
                    android:text="@string/save_change"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_16sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/user_pic_iv"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/user_pic_iv" />

                <TextView
                    android:id="@+id/changePassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:elevation="4dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/change_password"
                    android:textColor="@color/black"
                    app:layout_constraintBottom_toBottomOf="@+id/password_et"
                    app:layout_constraintEnd_toEndOf="@+id/password_et"
                    app:layout_constraintTop_toTopOf="@+id/password_et" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/user_pic_iv"
                    android:layout_width="97dp"
                    android:layout_height="97dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    android:src="@drawable/ic_user"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/change_photo_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:fontFamily="@font/roboto_black"
                    android:text="@string/change_photo"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_16sp"
                    app:layout_constraintBottom_toBottomOf="@+id/user_pic_iv"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/user_pic_iv" />

                <EditText
                    android:id="@+id/user_name_et"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:background="@drawable/bg_edit_text"
                    android:fontFamily="@font/roboto_regular"
                    android:hint="@string/enter_your_name"
                    android:inputType="text"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    android:paddingStart="@dimen/padding_16dp"
                    android:paddingTop="@dimen/radius_5dp"
                    android:paddingBottom="@dimen/radius_5dp"
                    android:scrollHorizontally="true"
                    android:textColor="@color/black"
                    android:text="@={data.displayName}"
                    android:textColorHint="@color/hint_color"
                    android:textSize="@dimen/text_size_16sp"
                    app:layout_constraintTop_toBottomOf="@+id/user_pic_iv" />

                <EditText
                    android:id="@+id/email_et"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:background="@drawable/bg_edit_text"
                    android:editable="false"
                    android:enabled="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:fontFamily="@font/roboto_regular"
                    android:hint="@string/enter_your_email"
                    android:inputType="textEmailAddress"
                    android:paddingStart="@dimen/padding_16dp"
                    android:paddingTop="@dimen/radius_5dp"
                    android:paddingBottom="@dimen/radius_5dp"
                    android:scrollHorizontally="true"
                    android:text="@={data.email}"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hint_color"
                    android:textSize="@dimen/text_size_16sp"
                    app:layout_constraintEnd_toEndOf="@+id/user_name_et"
                    app:layout_constraintStart_toStartOf="@+id/user_name_et"
                    app:layout_constraintTop_toBottomOf="@+id/user_name_et" />

                <EditText
                    android:id="@+id/password_et"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:background="@drawable/bg_edit_text"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:fontFamily="@font/roboto_regular"
                    android:hint="@string/enter_password"
                    android:inputType="textPassword"
                    android:paddingStart="@dimen/padding_16dp"
                    android:paddingTop="@dimen/radius_5dp"
                    android:paddingBottom="@dimen/radius_5dp"
                    android:scrollHorizontally="true"
                    android:text="jobayerjim9@gmail.com"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hint_color"
                    android:textSize="@dimen/text_size_16sp"
                    app:layout_constraintEnd_toEndOf="@+id/email_et"
                    app:layout_constraintStart_toStartOf="@+id/email_et"
                    app:layout_constraintTop_toBottomOf="@+id/email_et" />

                <RelativeLayout
                    android:id="@+id/date_rl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/password_et"
                    android:background="@drawable/bg_edit_text">

                    <ImageView
                        android:id="@+id/calender_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/margin_top_16dp"
                        android:src="@drawable/ic_calendar"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/image_description"/>

                    <TextView
                        android:id="@+id/date_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_regular"
                        android:text="@{data.dateOfBirth.empty ? @string/date_of_birth : data.dateOfBirth}"
                        android:textColor="@color/black"
                        android:textColorHint="@color/hint_color"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/gender_rl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/date_rl"
                    android:background="@drawable/bg_edit_text">

                    <ImageView
                        android:id="@+id/drop_down_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/margin_top_16dp"
                        android:src="@drawable/ic_drop_down"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/image_description"/>

                    <TextView
                        android:id="@+id/gender_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_regular"
                        android:hint="@string/gender"
                        android:text="@{data.gender.empty ? @string/gender : data.gender}"
                        android:textColor="@color/black"
                        android:textColorHint="@color/hint_color"
                        android:textSize="@dimen/text_size_16sp" />
                </RelativeLayout>


                <TextView
                    android:id="@+id/orbis_version_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="@string/orbis_version"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/roboto_regular"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/gender_rl" />

                <RelativeLayout
                    android:id="@+id/comment_rl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    app:layout_constraintTop_toBottomOf="@+id/orbis_version_tv"
                    android:background="@drawable/bg_setting_btn">

                    <TextView
                        android:id="@+id/comment_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/comment"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/roboto_bold"
                        android:layout_centerHorizontal="true"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/sponsors_rl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:visibility="gone"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_11dp"
                    app:layout_constraintTop_toBottomOf="@+id/comment_rl"
                    android:background="@drawable/bg_setting_btn">

                    <TextView
                        android:id="@+id/sponsors_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/sponsors"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/roboto_bold"
                        android:layout_centerHorizontal="true"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/rate_app_rl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_11dp"
                    app:layout_constraintTop_toBottomOf="@+id/comment_rl"
                    android:background="@drawable/bg_setting_btn">

                    <TextView
                        android:id="@+id/rate_app_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/rate_app"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/roboto_bold"
                        android:layout_centerHorizontal="true"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/invite_friends_rl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_11dp"
                    app:layout_constraintTop_toBottomOf="@+id/rate_app_rl"
                    android:background="@drawable/bg_setting_btn">

                    <TextView
                        android:id="@+id/invite_friends_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/invite_friends"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/deleteMyAccount"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/bg_setting_btn"
                    app:layout_constraintEnd_toEndOf="@+id/termsOfService"
                    app:layout_constraintStart_toStartOf="@+id/termsOfService"
                    app:layout_constraintTop_toBottomOf="@+id/service_terms_rl">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/delete_my_account"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/logout_rl"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/bg_setting_btn"
                    app:layout_constraintEnd_toEndOf="@+id/deleteMyAccount"
                    app:layout_constraintStart_toStartOf="@+id/deleteMyAccount"
                    app:layout_constraintTop_toBottomOf="@+id/deleteMyAccount">

                    <TextView
                        android:id="@+id/logout_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/logout"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_16sp" />

                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    app:layout_constraintTop_toBottomOf="@+id/logout_rl" />


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>