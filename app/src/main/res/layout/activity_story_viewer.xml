<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="segmentTime"
            type="Integer" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:paddingTop="20dp"
        tools:context=".ui.storiesModule.views.StoryViewerActivity">

        <pt.tornelas.segmentedprogressbar.SegmentedProgressBar
            android:id="@+id/spb"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_margin="8dp"
            android:layout_marginTop="16dp"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toTopOf="parent"
            app:segmentBackgroundColor="#707070"
            app:segmentCornerRadius="4dp"
            app:segmentMargins="4dp"
            app:segmentSelectedBackgroundColor="@color/white"

            app:segmentStrokeWidth="0dp"
            app:timePerSegment="4000"
            app:totalSegments="10" />

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        </androidx.viewpager.widget.ViewPager>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>