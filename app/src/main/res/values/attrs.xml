<?xml version="1.0" encoding="utf-8"?>
<resources>

<declare-styleable name="verticalSeekBar">
        <attr name="thumb" format="integer" />
    </declare-styleable>

    <declare-styleable name="constraintAttr">
        <attr name="sw_startValue" format="float" />
        <attr name="sw_value" format="float" />
        <attr name="sw_unit" format="string" />
        <attr name="sw_showText" format="boolean" />
        <attr name="sw_maxValue" format="float" />
        <attr name="sw_numberOfLine" format="integer" />
    </declare-styleable>
    <declare-styleable name="meterAttr">
        <attr name="sw_meterColor" format="color" />
        <attr name="sw_lineStrokeSize" format="dimension" />
        <attr name="sw_lineWidth" format="float" />
        <attr name="sw_showNeedle" format="boolean" />
    </declare-styleable>
    <declare-styleable name="progressAttr">
        <attr name="sw_radius" format="dimension" />
        <attr name="sw_progressColor" format="color" />
        <attr name="sw_progressText" format="string" />
        <attr name="sw_progressTextSize" format="dimension" />
        <attr name="sw_progressTextStyle" format="enum">
            <enum name="normal" value="0" />
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
        </attr>
        <attr name="sw_progressValue" format="float" />
        <attr name="sw_progressPadding" format="dimension" />
        <attr name="sw_progressIconPadding" format="dimension" />
        <attr name="sw_withAnimation" format="boolean" />
        <attr name="sw_duration" format="integer" />
        <attr name="sw_progressTextAppearance" format="reference" />
        <attr name="sw_progressBackground" format="color" />
        <attr name="sw_progressIcon" format="reference" />
    </declare-styleable>
    <declare-styleable name="propertiesAttr">
        <attr name="sw_message" format="string" />
        <attr name="sw_innerPadding" format="dimension" />
        <attr name="sw_innerLeftPadding" format="dimension" />
        <attr name="sw_innerTopPadding" format="dimension" />
        <attr name="sw_innerRightPadding" format="dimension" />
        <attr name="sw_innerBottomPadding" format="dimension" />
        <attr name="sw_drawable" format="reference" />
        <attr name="sw_drawablePadding" format="dimension" />
        <attr name="sw_boxBackground" format="color" />
    </declare-styleable>
    <declare-styleable name="textAttr">
        <attr name="sw_textSize" format="dimension" />
        <attr name="sw_textStyle" format="enum">
            <enum name="normal" value="0" />
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
        </attr>
    </declare-styleable>

    <declare-styleable name="ReadMoreTextView">
        <attr name="trimExpandedText" format="string" />
        <attr name="trimCollapsedText" format="string" />
        <attr name="trimLength" format="integer" />
        <attr name="showTrimExpandedText" format="boolean" />
        <attr name="colorClickableText" format="color" />
        <attr name="trimLines" format="integer" />
        <attr name="trimMode">
            <enum name="trimModeLine" value="0" />
            <enum name="trimModeLength" value="1" />
        </attr>
    </declare-styleable>

    <declare-styleable name="RoundLinerLayoutNormal">
        <attr name="rll_elevation" format="dimension" />
        <attr name="rll_shadow_radius" format="dimension" />
        <attr name="rll_shadow_color" format="color" />
        <attr name="rll_shadow_bkg_color" format="color" />
        <attr name="rll_shadow_dx" format="dimension" />
        <attr name="rll_shadow_dy" format="dimension" />
        <attr name="rll_inset_left" format="dimension" />
        <attr name="rll_inset_top" format="dimension" />
        <attr name="rll_inset_right" format="dimension" />
        <attr name="rll_inset_bottom" format="dimension" />
        <attr name="rll_shadow_gravity">
            <flag name="bottom" value="80" />
            <flag name="center" value="17" />
            <flag name="center_horizontal" value="1" />
            <flag name="center_vertical" value="16" />
            <flag name="clip_horizontal" value="8" />
            <flag name="clip_vertical" value="128" />
            <flag name="end" value="8388613" />
            <flag name="fill" value="119" />
            <flag name="fill_horizontal" value="7" />
            <flag name="fill_vertical" value="112" />
            <flag name="left" value="3" />
            <flag name="right" value="5" />
            <flag name="start" value="8388611" />
            <flag name="top" value="48" />
        </attr>
    </declare-styleable>
    <declare-styleable name="StoriesProgressView">
        <attr name="progressCount" format="integer|reference" />
    </declare-styleable>
</resources>