<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_marginHorizontal="@dimen/margin_16dp"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/title_ll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_windows_info"
        android:padding="@dimen/radius_5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/title_cardview"
            android:layout_width="@dimen/windows_title_width"
            android:layout_height="45dp">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/title_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/map_circle_pin"
                    android:fontFamily="@font/roboto_bold"
                    android:gravity="center"
                    android:text="Amantes de pizza italiana"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_12sp" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sub_title_ll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_top_8dp"
        android:layout_marginBottom="@dimen/margin_bottom_8dp"
        android:background="@drawable/bg_windows_info"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="@dimen/radius_5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_ll">

        <androidx.cardview.widget.CardView
            android:id="@+id/sub_title_cardview"
            android:layout_width="@dimen/windows_sub_title_width"
            android:layout_height="45dp"
            app:cardBackgroundColor="@color/white"


            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_cardview">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/sub_title_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:maxLength="40"
                    android:layout_marginStart="@dimen/margin_start_8dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_toEndOf="@+id/location_iv"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="center"
                    android:text="Pizzaria Veneza"
                    android:textColor="@color/sub_title_color"
                    android:textSize="@dimen/text_size_12sp" />

                <ImageView
                    android:id="@+id/location_iv"
                    android:layout_width="@dimen/location_type_icon_size"
                    android:layout_height="@dimen/location_type_icon_size"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:contentDescription="@string/image_description"
                    android:src="@drawable/ic_pizzaria" />

            </RelativeLayout>


        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>