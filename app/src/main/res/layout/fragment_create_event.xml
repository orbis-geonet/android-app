<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="loading"
            type="Boolean" />

        <variable
            name="data"
            type="com.orbis.orbis.models.posts.PostBody" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/loader25"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerInParent="true"
            android:layout_centerVertical="false"
            android:elevation="8dp"
            android:visibility="@{loading ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_autoPlay="true"
            app:lottie_fileName="loader.json"
            app:lottie_loop="true" />

        <View
            android:id="@+id/view"
            android:layout_width="130dp"
            android:layout_height="2dp"
            android:layout_marginTop="@dimen/radius_10dp"
            android:background="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <include
            android:id="@+id/toolbar"
            layout="@layout/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_top_8dp"
            app:layout_constraintTop_toBottomOf="@+id/view" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="60dp"
            android:clipToPadding="false"

            android:fillViewport="true"
            app:layout_constrainedHeight="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar"
            app:layout_constraintVertical_bias="0.0">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/select_type_cl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="true"
                app:layout_constraintBottom_toTopOf="@+id/create_place_btn"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/toolbar">

                <TextView
                    android:id="@+id/post_as_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_regular"
                    android:gravity="center"
                    android:text="@string/publish_as"
                    android:textColor="@color/icons_grey_color"
                    android:textSize="@dimen/text_size_14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:visibility="visible" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/select_user_cl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:background="@drawable/bg_grey_rect"
                    app:layout_constraintTop_toBottomOf="@+id/post_as_tv">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/image_iv"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:layout_marginTop="@dimen/margin_top_16dp"
                        android:contentDescription="@string/image_description"
                        android:src="@drawable/image_test2"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/place_name_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="Pedra da Praia"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_16sp"
                        app:layout_constraintBottom_toBottomOf="@+id/image_iv"
                        app:layout_constraintStart_toEndOf="@+id/image_iv"
                        app:layout_constraintTop_toTopOf="@+id/image_iv" />

                    <ImageView
                        android:id="@+id/arrow_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_marginTop="@dimen/margin_top_16dp"
                        android:layout_marginEnd="@dimen/margin_end_8dp"
                        android:contentDescription="@string/image_description"
                        android:padding="8dp"
                        android:src="@drawable/ic_down_arrow"
                        app:layout_constraintBottom_toBottomOf="@+id/image_iv"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/search_post_as_cl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_grey_rect"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/image_iv">

                        <LinearLayout
                            android:id="@+id/search_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"

                            android:layout_marginTop="@dimen/margin_top_8dp"
                            android:layout_marginEnd="@dimen/margin_top_16dp"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_top_16dp"
                                android:layout_marginTop="@dimen/margin_12dp"
                                android:layout_marginBottom="@dimen/margin_12dp"
                                android:contentDescription="@string/image_description"
                                android:src="@drawable/ic_search" />

                            <androidx.appcompat.widget.SearchView
                                android:id="@+id/search_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"

                                android:layout_marginStart="@dimen/margin_top_16dp"
                                app:defaultQueryHint="Search"
                                app:iconifiedByDefault="false"
                                app:queryBackground="@null"
                                app:queryHint="Search"
                                app:searchHintIcon="@null"
                                app:searchIcon="@null"
                                app:theme="@style/AppSearchView" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/places_rv"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:clipToPadding="false"
                            android:minHeight="50dp"
                            android:paddingTop="@dimen/padding_8dp"
                            android:paddingBottom="@dimen/padding_8dp"
                            app:layout_constrainedHeight="true"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/search_layout"
                            tools:itemCount="5"
                            tools:listitem="@layout/each_group_create_post_layout" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="@dimen/margin_top_16dp"
                        android:layout_marginEnd="@dimen/margin_end_16dp"
                        android:background="@color/camera_bg_color"
                        android:visibility="invisible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/search_post_as_cl" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/your_event_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="102dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="@string/your_event"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/post_as_tv"
                    tools:visibility="visible" />

                <EditText
                    android:id="@+id/event_title_et"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_edit_text"
                    android:fontFamily="@font/roboto_regular"
                    android:hint="@string/event_title"
                    android:inputType="text"
                    android:minHeight="@dimen/edit_text_height"
                    android:paddingStart="@dimen/padding_16dp"
                    android:paddingEnd="@dimen/padding_16dp"
                    android:scrollHorizontally="true"
                    android:text="@={data.title}"
                    android:textColor="@color/text_black"
                    android:textColorHint="@color/hint_color"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/your_event_tv" />

                <EditText
                    android:id="@+id/event_address_et"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_edit_text"
                    android:clickable="false"
                    android:focusable="false"
                    android:fontFamily="@font/roboto_regular"
                    android:inputType="none"
                    android:minHeight="@dimen/edit_text_height"
                    android:paddingStart="@dimen/padding_16dp"
                    android:paddingEnd="@dimen/padding_16dp"
                    android:scrollHorizontally="true"
                    android:textColor="@color/text_black"
                    android:textColorHint="@color/hint_color"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/event_title_et" />

                <LinearLayout
                    android:id="@+id/date_time_ll"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/edit_text_height"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:weightSum="4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/event_address_et">

                    <TextView
                        android:id="@+id/event_date_et"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/edit_text_height"
                        android:layout_weight="1.8"
                        android:background="@drawable/bg_edit_text"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:fontFamily="@font/roboto_regular"
                        android:gravity="center"
                        android:hint="@string/date"
                        android:inputType="text"
                        android:minHeight="@dimen/edit_text_height"
                        android:scrollHorizontally="true"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        tools:ignore="TextViewEdits" />

                    <TextView
                        android:id="@+id/event_start_et"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/edit_text_height"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:layout_weight="1.1"
                        android:background="@drawable/bg_edit_text"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:fontFamily="@font/roboto_regular"
                        android:gravity="center"
                        android:hint="@string/start"
                        android:inputType="text"
                        android:minHeight="@dimen/edit_text_height"
                        android:scrollHorizontally="true"
                        android:textColor="@color/text_black"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/event_end_et"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/edit_text_height"
                        android:layout_marginStart="@dimen/margin_start_16dp"
                        android:layout_weight="1.1"
                        android:background="@drawable/bg_edit_text"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:fontFamily="@font/roboto_regular"
                        android:gravity="center"
                        android:hint="@string/end"
                        android:inputType="text"
                        android:minHeight="@dimen/edit_text_height"
                        android:scrollHorizontally="true"
                        android:textColor="@color/text_black"
                        android:textSize="@dimen/text_size_12sp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/event_about_et"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="@dimen/margin_top_8dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_edit_text"
                    android:fontFamily="@font/roboto_regular"
                    android:gravity="top"
                    android:hint="@string/event_description"
                    android:inputType="textMultiLine"
                    android:lines="3"
                    android:minHeight="@dimen/edit_text_height"
                    android:paddingStart="@dimen/padding_16dp"
                    android:paddingTop="@dimen/padding_16dp"
                    android:paddingEnd="@dimen/padding_16dp"
                    android:paddingBottom="@dimen/radius_5dp"
                    android:scrollHorizontally="true"
                    android:text="@={data.details}"
                    android:textColor="@color/text_black"
                    android:textColorHint="@color/hint_color"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/date_time_ll" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/media_bg_cl"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:background="@drawable/bg_gray_border_rect"
                    app:layout_constraintTop_toBottomOf="@+id/event_about_et">


                    <Button
                        android:id="@+id/add_photo_btn"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="120dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="false"
                        android:drawableStart="@drawable/ic_photo"
                        android:drawableTint="@color/hint_color"
                        android:fontFamily="@font/roboto_bold"
                        android:paddingStart="@dimen/margin_top_24dp"
                        android:paddingEnd="@dimen/margin_top_24dp"
                        android:text="@string/photo"
                        android:textAllCaps="false"
                        android:textColor="@color/hint_color"
                        android:textSize="@dimen/text_size_12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/photo_cl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/black"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/event_about_et"
                    tools:visibility="gone">

                    <ImageView
                        android:id="@+id/photo_iv"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:contentDescription="@string/image_description"
                        android:src="@drawable/post_image"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/close_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_margin="@dimen/margin_start_16dp"
                        android:contentDescription="@string/image_description"
                        android:src="@drawable/ic_close_circle"
                        app:elevation="@dimen/elevation_2dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/hint_color" />
                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/create_event_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginEnd="@dimen/margin_end_16dp"
            android:layout_marginBottom="@dimen/margin_bottom_16dp"
            android:layout_marginTop="@dimen/margin_top_16dp"
            android:background="@drawable/black_btn"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/create_event"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_16sp"
            android:textStyle="bold" />
    </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>