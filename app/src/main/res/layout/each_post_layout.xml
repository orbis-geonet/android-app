<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="data"
            type="com.orbis.orbis.models.group.FeedPost" />

        <variable
            name="imageLink"
            type="String" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_id"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/post_cl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:tabBackground="@drawable/tab_dots_layout_selector"
                app:tabGravity="center"
                app:tabIndicator="@null"
                app:tabIndicatorColor="@android:color/transparent"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="20dp"
                app:tabMode="fixed"
                app:tabPadding="8dp"
                app:tabRippleColor="@null"
                app:tabSelectedTextColor="@color/black"
                app:tabTextAppearance="@style/tabsStyle" />

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/check_in_viewpager"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="16dp"
                android:background="@color/black"
                app:layout_constraintBottom_toTopOf="@+id/tab_layout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/post_tv"
                app:layout_constraintVertical_bias="0.0">

            </androidx.viewpager.widget.ViewPager>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/user_cl"
                android:layout_width="@dimen/_0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="@dimen/margin_bottom_24dp"
                android:layout_marginEnd="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/user_shadow_circle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:civ_border_color="@{data.group.strokeColorHex}"

                    app:civ_border_width="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <TextView
                    android:id="@+id/user_name_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_12dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_bold"
                    android:maxLines="1"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_16sp"
                    app:layout_constraintEnd_toStartOf="@+id/user_menu_iv"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@id/user_shadow_circle"
                    app:layout_constraintTop_toTopOf="@+id/user_shadow_circle" />

                <TextView
                    android:id="@+id/date_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"

                    android:fontFamily="@font/roboto_regular"
                    android:textColor="@color/hint_color"
                    android:textSize="@dimen/text_size_12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/user_shadow_circle"
                    app:layout_constraintStart_toStartOf="@id/user_name_tv"
                    app:layout_constraintTop_toBottomOf="@id/user_name_tv"
                    tools:ignore="SmallSp" />

                <ImageView
                    android:id="@+id/location_pin_iv"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="@dimen/margin_start_8dp"
                    android:contentDescription="@string/image_description"
                    android:src="@drawable/ic_location_mark"
                    app:layout_constraintBottom_toBottomOf="@+id/date_tv"
                    app:layout_constraintStart_toEndOf="@+id/date_tv"
                    app:layout_constraintTop_toTopOf="@+id/date_tv" />

                <TextView
                    android:id="@+id/location_name_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/roboto_regular"
                    android:maxLines="1"
                    android:text="@{data.place.name}"
                    android:textColor="@color/hint_color"
                    android:textSize="@dimen/text_size_12sp"
                    app:layout_constraintEnd_toStartOf="@+id/user_menu_iv"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@id/location_pin_iv"
                    app:layout_constraintTop_toTopOf="@+id/date_tv"
                    tools:ignore="SmallSp" />

                <ImageView
                    android:id="@+id/user_menu_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:src="@drawable/ic_menu"
                    app:layout_constraintBottom_toBottomOf="@id/user_shadow_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/user_shadow_circle"
                    app:popupTheme="@style/PopupMenu" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.orbis.orbis.utils.customViews.ViewMoreTextView
                android:id="@+id/post_tv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:autoLink="web"
                android:textColorLink="#0000FF"
                android:layout_marginTop="@dimen/margin_bottom_24dp"
                android:layout_marginEnd="16dp"
                android:lineSpacingExtra="4sp"
                android:textColor="@color/post_color"
                android:textSize="16sp"
                android:textStyle="normal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/user_cl"
                app:layout_constraintTop_toBottomOf="@id/user_cl" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/comment_cl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="@dimen/margin_top_24dp"
            android:layout_marginEnd="@dimen/margin_end_16dp"
            app:layout_constraintTop_toBottomOf="@+id/post_cl">

            <ImageView
                android:id="@+id/likes_iv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_tick"
                app:layout_constraintBottom_toBottomOf="@id/comments_iv"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/comments_iv" />

            <TextView
                android:id="@+id/likes_tv"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/margin_start_8dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:gravity="center"
                android:text="247"
                android:textColor="@color/likes_color"
                android:textSize="@dimen/text_size_12sp"
                app:layout_constraintBottom_toBottomOf="@+id/likes_iv"
                app:layout_constraintStart_toEndOf="@id/likes_iv"
                app:layout_constraintTop_toTopOf="@+id/likes_iv" />

            <ImageView
                android:id="@+id/comments_iv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_start_32dp"
                android:src="@drawable/ic_comment"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/likes_tv"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/comments_tv"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/margin_start_8dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:text="57"
                android:textColor="@color/likes_color"
                android:textSize="@dimen/text_size_12sp"
                app:layout_constraintBottom_toBottomOf="@+id/likes_tv"
                app:layout_constraintStart_toEndOf="@id/comments_iv"
                app:layout_constraintTop_toTopOf="@+id/likes_tv" />

            <TextView
                android:id="@+id/share_name_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_bold"
                android:text="@{data.user.displayName==null &amp;&amp; data.user.displayName.empty ? @string/orbis_user : data.user.displayName }"
                android:textColor="@color/hint_color"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/share_icon_iv" />


            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/share_icon_iv"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/image_description"
                android:src="@drawable/ic_user"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/share_name_tv"
                app:layout_constraintTop_toTopOf="parent"
               />


        </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="1.5dp"
        android:layout_marginTop="@dimen/margin_bottom_24dp"
        android:background="@color/line_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/comment_cl" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>