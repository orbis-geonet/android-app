<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.exoplayer2.ui.PlayerView
            android:id="@+id/storyDisplayVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:surface_type="texture_view" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/storyDisplayImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <ProgressBar
            android:id="@+id/storyDisplayVideoProgress"
            style="?android:attr/progressBarStyleInverse"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:indeterminateTint="@color/likes_color"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <View
                android:id="@+id/previous"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2" />

            <View
                android:id="@+id/next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3" />
        </LinearLayout>

        <TextView
            android:id="@+id/full_screen_post_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="@dimen/margin_top_16dp"
            android:layout_marginEnd="@dimen/margin_end_16dp"
            android:elevation="@dimen/_0dp"
            android:fontFamily="@font/roboto_regular"
            android:lineHeight="24sp"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/storyOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/view4"
                android:layout_width="match_parent"
                android:layout_height="89dp"
                android:background="@drawable/story_top_shadow"
                app:layout_constraintTop_toTopOf="parent" />

            <com.orbis.orbis.ui.storiesModule.adapter.StoriesProgressView
                android:id="@+id/storiesProgressView"
                android:layout_width="match_parent"
                android:layout_height="15dp"
                android:layout_gravity="top"
                android:layout_marginTop="8dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/storyDisplayProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                app:layout_constraintTop_toBottomOf="@+id/storiesProgressView">


                <com.orbis.orbis.utils.customViews.RoundLinerLayoutNormal
                    android:id="@+id/shadow_circle"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:rll_elevation="@dimen/elevation_6dp"
                    app:rll_shadow_bkg_color="@color/white"
                    app:rll_shadow_color="@color/shadowColor"
                    app:rll_shadow_radius="25dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/storyDisplayProfilePicture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="3dp"
                        android:src="@drawable/group3" />
                </com.orbis.orbis.utils.customViews.RoundLinerLayoutNormal>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/storyDisplayNick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="username" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/storyDisplayTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_regular"
                            android:textColor="#ffffff"
                            android:textSize="12sp"
                            tools:text="nm ago" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/view3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/story_top_shadow"
                android:paddingBottom="@dimen/margin_bottom_16dp"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/storyUserProfilePicture"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/view3" />

                <TextView
                    android:id="@+id/storyUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="#ffffff"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/storyUserProfilePicture"
                    app:layout_constraintStart_toEndOf="@+id/storyUserProfilePicture"
                    app:layout_constraintTop_toTopOf="@+id/storyUserProfilePicture"
                    tools:text="username" />


                <ImageView
                    android:id="@+id/likes_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_tick"
                    app:layout_constraintBottom_toBottomOf="@id/comments_iv"
                    app:layout_constraintEnd_toStartOf="@+id/likes_tv"
                    app:layout_constraintTop_toTopOf="@id/comments_iv"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/likes_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="247"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_12sp"
                    app:layout_constraintBottom_toBottomOf="@id/likes_iv"
                    app:layout_constraintEnd_toStartOf="@+id/comments_iv"
                    app:layout_constraintTop_toTopOf="@id/likes_iv" />

                <ImageView
                    android:id="@+id/comments_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_comment"
                    app:layout_constraintBottom_toBottomOf="@+id/comments_tv"
                    app:layout_constraintEnd_toStartOf="@+id/comments_tv"
                    app:layout_constraintTop_toTopOf="@+id/comments_tv"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/comments_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_8dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="57"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/storyUsername"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/storyUsername" />

                <TextView
                    android:id="@+id/post_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:layout_marginBottom="@dimen/margin_bottom_16dp"
                    android:fontFamily="@font/roboto_regular"
                    android:text="Lorem ipsum dolor sit amet, consetetur sadipscingStet  dolor Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_14sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/storyUserProfilePicture" />
            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>