<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="com.orbis.orbis.helpers.PrefManager" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/language_title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/language"
                android:textColor="@color/black"
                android:fontFamily="@font/roboto_regular"
                android:layout_centerHorizontal="true"
                android:textSize="@dimen/text_size_16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginEnd="@dimen/margin_end_16dp"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="@dimen/margin_top_16dp"
                />

            <RelativeLayout
                android:id="@+id/selected_language_rl"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edit_text_height"
                android:layout_marginEnd="@dimen/margin_end_16dp"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="@dimen/margin_top_8dp"
                app:layout_constraintTop_toBottomOf="@+id/language_title_tv"
                android:background="@drawable/bg_setting_btn"
                >
                <TextView
                    android:id="@+id/selected_language_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"

                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/roboto_bold"
                    android:layout_centerHorizontal="true"
                    android:textSize="@dimen/text_size_14sp"
                    />
            </RelativeLayout>


            <TextView
                android:id="@+id/push_notification_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/roboto_regular"
                android:text="@string/push_notification"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/selected_language_rl" />


            <LinearLayout
                android:id="@+id/push_notification_ll"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edit_text_height"
                android:orientation="horizontal"
                android:layout_marginEnd="@dimen/margin_end_16dp"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="@dimen/margin_top_8dp"
                app:layout_constraintTop_toBottomOf="@+id/push_notification_tv"
                android:weightSum="2">

                <Button
                    android:id="@+id/btn_on"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/toggle_button_left"
                    android:fontFamily="@font/roboto_bold"
                    android:text="@string/on"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size_14sp"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/btn_off"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/toggle_button_right"
                    android:fontFamily="@font/roboto_bold"
                    android:text="@string/off"
                    android:textSize="@dimen/text_size_14sp"
                    android:textAllCaps="false"
                    android:textColor="@color/black" />

            </LinearLayout>

            <RelativeLayout
                android:id="@+id/reset_settings_rl"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edit_text_height"
                android:layout_marginEnd="@dimen/margin_end_16dp"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="@dimen/margin_top_32dp"
                app:layout_constraintTop_toBottomOf="@+id/push_notification_ll"
                android:background="@drawable/bg_setting_btn"
                >
                <TextView
                    android:id="@+id/reset_settings_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="@string/reset_settings"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/roboto_bold"
                    android:layout_centerHorizontal="true"
                    android:textSize="@dimen/text_size_14sp" />
            </RelativeLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>