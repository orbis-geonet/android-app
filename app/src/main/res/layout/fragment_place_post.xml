<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="data"
            type="com.orbis.orbis.models.place.PlaceDetails" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">



            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/map">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/map_cl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <fragment
                        android:id="@+id/map"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="186dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/line_opacity"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@drawable/gradient_bg"
                        android:orientation="horizontal"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="@+id/map" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/place_title_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="@font/roboto_bold"
                    android:lineSpacingExtra="1dp"
                    tools:text="rwewe r ewrwrwer wr wer werwerwerwr"
                    android:text="@{data.name}"
                    android:ellipsize="end"
                    android:lines="1"
                    android:maxLines="1"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    app:layout_constraintEnd_toStartOf="@+id/confirm_iv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/map_cl" />


                <ImageView
                    android:id="@+id/confirm_iv"
                    android:layout_width="@dimen/confirm_size"
                    android:layout_height="@dimen/confirm_size"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_confirm"
                    app:layout_constraintBottom_toBottomOf="@+id/place_title_tv"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/place_title_tv" />


                <TextView
                    android:id="@+id/event_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_bottom_8dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    android:fontFamily="@font/roboto_regular"
                    android:text="@{data.description}"
                    android:textColor="@color/post_color"
                    android:textSize="@dimen/text_size_14sp"
                    app:layout_constraintTop_toBottomOf="@id/place_title_tv"
                    app:layout_goneMarginTop="@dimen/margin_top_8dp" />

                <TextView
                    android:id="@+id/group_title_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Groups in that place"
                    android:textColor="@color/post_color"
                    android:textSize="@dimen/text_size_14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/event_tv" />

                <com.orbis.orbis.utils.customViews.RoundLinerLayoutNormal
                    android:id="@+id/group_shadow_circle"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="@dimen/margin_top_16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/group_title_tv"
                    app:rll_elevation="@dimen/elevation_6dp"
                    app:rll_shadow_bkg_color="@color/white"
                    app:rll_shadow_color="@color/icons_grey_color"
                    app:rll_shadow_radius="25dp">
                    <ImageView
                        android:id="@+id/group_icon_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_border"
                        android:padding="3dp"
                        android:src="@drawable/group3"
                        android:contentDescription="@string/image_description" />
                </com.orbis.orbis.utils.customViews.RoundLinerLayoutNormal>

                <TextView
                    android:id="@+id/group_name_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Amantes de pizza"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_14sp"
                    app:layout_constraintBottom_toBottomOf="@+id/group_shadow_circle"
                    app:layout_constraintStart_toEndOf="@+id/group_shadow_circle"
                    app:layout_constraintTop_toTopOf="@+id/group_shadow_circle" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/group_images_rv"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="@dimen/margin_start_8dp"
                    android:layout_marginEnd="@dimen/margin_end_16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/group_shadow_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/group_name_tv"
                    app:layout_constraintTop_toTopOf="@+id/group_shadow_circle"
                    tools:listitem="@layout/each_group_icon_item" />

                <com.orbis.orbis.utils.customViews.ColoredProgressBar
                    android:id="@+id/progress_horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_margin="@dimen/margin_16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/group_shadow_circle"
                    app:sw_radius="7dp" />

                <TextView
                    android:id="@+id/feed_title_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_16dp"
                    android:layout_marginTop="@dimen/margin_top_24dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Feed"
                    android:textColor="@color/post_color"
                    android:textSize="@dimen/text_size_14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/progress_horizontal" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/posts_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="@dimen/padding_bottom_90dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/feed_title_tv"
                    tools:listitem="@layout/each_place_post_layout" />


            </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/back_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_start_32dp"
        android:backgroundTint="@color/white"
        app:tint="@color/icons_grey_color"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_back_arrow"
        app:borderWidth="@dimen/_0dp"
        app:fabCustomSize="@dimen/fab_size"
        app:elevation="@dimen/elevation_5dp"
        app:layout_constraintBottom_toBottomOf="@+id/add_fab"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/add_fab"
        app:maxImageSize="@dimen/fab_icon_size" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_bottom_24dp"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_add_post"
        app:borderWidth="@dimen/_0dp"
        app:fabCustomSize="@dimen/add_fab_size"
        app:elevation="@dimen/elevation_5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:maxImageSize="@dimen/add_fab_icon_size" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/event_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_start_32dp"
        android:backgroundTint="@color/white"
        app:tint="@color/icons_grey_color"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_event"
        app:borderWidth="@dimen/_0dp"
        app:fabCustomSize="@dimen/fab_size"
        app:elevation="@dimen/elevation_5dp"
        app:layout_constraintBottom_toBottomOf="@+id/add_fab"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/add_fab"
        app:maxImageSize="@dimen/fab_icon_size" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>