<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="loading"
            type="Boolean" />
    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/groupListFragment"
        android:elevation="15dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Handle -->
        <View
            android:id="@+id/handle"
            android:layout_width="105dp"
            android:layout_height="5dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_handle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nearby_communities"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/handle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:elevation="20dp"
            android:id="@+id/search_layout"
            android:visibility="gone"
            tools:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/title">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:src="@drawable/ic_search" />

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:theme="@style/AppSearchView2"
                app:queryHint="Search tribe here..."
                app:iconifiedByDefault="false"
                app:queryBackground="@null"
                app:searchHintIcon="@null"
                app:searchIcon="@null" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/groups_rv"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:paddingBottom="110dp"
            android:paddingTop="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/search_layout"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:listitem="@layout/each_group_row_layout"
            tools:itemCount="5" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottomActionsContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/add_fab"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="50dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="@dimen/elevation_5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/logo_fab"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:contentDescription="@string/image_description"
                    android:elevation="@dimen/radius_10dp"
                    android:padding="16dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/ic_plus" />
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_end_32dp"
                android:backgroundTint="@color/white"
                android:contentDescription="@string/floatingactionbuttondescription"
                android:src="@drawable/ic_logotipo"
                app:borderWidth="@dimen/_0dp"
                app:tint="#000000"
                app:elevation="@dimen/elevation_5dp"
                app:fabCustomSize="@dimen/fab_size"
                app:layout_constraintBottom_toBottomOf="@+id/add_fab"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/add_fab"
                app:maxImageSize="@dimen/fab_icon_size" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/news_feed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_start_32dp"
                android:backgroundTint="@color/white"
                android:contentDescription="@string/floatingactionbuttondescription"
                android:src="@drawable/ic_news"
                app:tint="#BFBFBF"
                app:borderWidth="@dimen/_0dp"
                app:elevation="@dimen/elevation_5dp"
                app:fabCustomSize="@dimen/fab_size"
                app:layout_constraintBottom_toBottomOf="@+id/add_fab"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/add_fab"
                app:maxImageSize="@dimen/fab_icon_size" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>