<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="data"
            type="com.orbis.orbis.models.place.PlaceDetails" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/view5"
            android:layout_width="@dimen/_0dp"
            android:layout_height="1.5dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:background="@color/line_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/shadow_circle" />


        <TextView
            android:id="@+id/textView6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/roboto_regular"
            android:text="@{data.name}"
            android:textColor="@color/black"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@+id/shadow_circle"
            app:layout_constraintEnd_toStartOf="@+id/unfollow"
            app:layout_constraintStart_toEndOf="@+id/shadow_circle"
            app:layout_constraintTop_toTopOf="@+id/shadow_circle" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/shadow_circle"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:src="@color/white"
            app:civ_border_color="@{data.dominantGroup.strokeColorHex}"
            app:civ_border_width="@dimen/elevation_3dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/placeImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:elevation="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/shadow_circle"
            app:layout_constraintEnd_toEndOf="@+id/shadow_circle"
            app:layout_constraintStart_toStartOf="@+id/shadow_circle"
            app:layout_constraintTop_toTopOf="@+id/shadow_circle"
            app:srcCompat="@drawable/ic_group_1" />

        <Button
            android:id="@+id/unfollow"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/border_black_btn"
            android:text="@string/unfollow"
            android:textAllCaps="false"
            app:layout_constraintBottom_toBottomOf="@+id/shadow_circle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/shadow_circle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>