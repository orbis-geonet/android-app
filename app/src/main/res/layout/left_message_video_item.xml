<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/rl_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            tools:ignore="UselessParent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cv_message_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:layout_marginTop="@dimen/margin_top_16dp"
                android:layout_marginBottom="1dp"
                android:background="@drawable/cc_message_bubble_left">

                <com.google.android.exoplayer2.ui.PlayerView
                    android:id="@+id/player_view"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:background="@color/black"
                    android:visibility="invisible"
                    app:controller_layout_id="@layout/custom_player_control"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/post_tv"
                    app:show_buffering="when_playing"
                    app:show_shuffle_button="false"
                    app:use_artwork="true" />

                <ImageView
                    android:id="@+id/play2"
                    android:layout_width="47dp"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp"
                    android:src="@drawable/ic_icon_play"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/imageMsg"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/imageMsg"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:elevation="1dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:maxWidth="229dp"
                    android:minWidth="50dp"
                    android:padding="@dimen/padding_8dp"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txt_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_start_8dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="@dimen/margin_bottom_8dp"
                    android:fontFamily="@font/roboto_regular"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/player_view"
                    app:layout_constraintVertical_bias="0.0"
                    tools:ignore="RtlHardcoded,RtlSymmetry"
                    tools:text="11:00 AM" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/img_pending"
                android:layout_width="15dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="-5dp"
                android:layout_marginTop="11dp"
                android:layout_marginEnd="5dp"
                android:layout_toEndOf="@+id/cv_message_container"
                android:visibility="visible" />


        </RelativeLayout>

    </LinearLayout>

</layout>