<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.orbis.orbis.models.place.PlaceDetails" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/map_cl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/view7"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/postMap" />

            <fragment
                android:id="@+id/postMap"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/line_opacity"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="-20dp"
                android:background="@drawable/gradient_home_bg"
                android:orientation="horizontal"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@id/postMap" />

        </androidx.constraintlayout.widget.ConstraintLayout>



        <LinearLayout
            android:id="@+id/noItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:elevation="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/feed_title_tv">

            <ImageView
                android:id="@+id/no_photo_iv3"
                android:layout_width="match_parent"
                android:layout_height="167dp"
                android:layout_marginTop="@dimen/margin_top_52dp"
                android:contentDescription="@string/image_description"
                android:src="@drawable/ic_connect_instagram"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/no_photo_tv3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_start_52dp"
                android:layout_marginTop="@dimen/margin_top_24dp"
                android:layout_marginEnd="@dimen/margin_end_52dp"
                android:fontFamily="@font/roboto_regular"
                android:gravity="center"
                android:text="@string/no_post_has_been_uploaded_to_this_group_yet"
                android:textSize="@dimen/text_size_14sp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@+id/no_photo_iv" />

        </LinearLayout>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/groupImage2"
            android:layout_width="40dp"
            android:layout_height="40dp"

            android:layout_marginTop="16dp"
            android:src="@drawable/ic_user"
            app:civ_border_color="@{data.dominantGroup.strokeColorHex}"
            app:civ_border_width="3dp"
            app:layout_constraintStart_toStartOf="@+id/group_title_tv"
            app:layout_constraintTop_toBottomOf="@+id/group_title_tv" />

        <TextView
            android:id="@+id/place_title_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="@dimen/margin_top_24dp"
            android:layout_marginEnd="16dp"
            android:lineSpacingExtra="5sp"
            android:text="@{data.name}"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:ellipsize="end"
            android:lines="1"
            android:maxLines="1"
            app:layout_constraintEnd_toStartOf="@+id/confirm_iv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/map_cl" />

        <ImageView
            android:id="@+id/confirm_iv"
            android:layout_width="@dimen/confirm_size"
            android:layout_height="@dimen/confirm_size"
            android:layout_marginEnd="@dimen/margin_end_16dp"
            android:padding="2dp"
            android:src="@drawable/ic_confirm"
            app:tint="@color/grey_state"
            app:layout_constraintBottom_toBottomOf="@+id/place_title_tv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/place_title_tv" />

        <FrameLayout
            android:id="@+id/ratingContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="@dimen/margin_bottom_8dp"
            android:layout_marginEnd="@dimen/margin_end_16dp"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            app:layout_constraintTop_toBottomOf="@id/place_title_tv">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/averageRateTextView"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_regular"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/ratingContainer" />

                <com.willy.ratingbar.ScaleRatingBar
                    android:id="@+id/simpleRatingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srb_numStars="5"
                    app:srb_drawableEmpty="@drawable/icon_awesome_star_empty"
                    app:srb_drawableFilled="@drawable/icon_awesome_star_fill"
                    app:srb_starWidth="16dp"
                    app:srb_starHeight="16dp"
                    app:srb_isIndicator="true"
                    app:srb_stepSize="0.1"/>

                <TextView
                    android:id="@+id/rateCountTextView"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_regular"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/ratingContainer" />

            </LinearLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/event_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="@dimen/margin_bottom_8dp"
            android:layout_marginEnd="@dimen/margin_end_16dp"
            android:fontFamily="@font/roboto_regular"
            android:text="@{data.description.empty ? @string/no_desc : data.description}"
            android:textColor="@color/post_color"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintTop_toBottomOf="@id/ratingContainer"
            app:layout_goneMarginTop="@dimen/margin_top_8dp" />

        <LinearLayout
            android:id="@+id/placeDetailContainer"
            app:layout_constraintStart_toStartOf="@+id/ratingContainer"
            app:layout_constraintTop_toBottomOf="@+id/event_tv"
            android:layout_width="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/addressImageView"
                android:layout_weight="1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="@dimen/margin_end_24dp"
                android:src="@drawable/address_9706"/>

            <ImageView
                android:id="@+id/telephoneImageView"
                android:layout_weight="1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="@dimen/margin_end_24dp"
                android:src="@drawable/telephone_9705"/>

            <ImageView
                android:id="@+id/openingTimeImageView"
                android:layout_weight="1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="@dimen/margin_end_24dp"
                android:src="@drawable/openingtime_9704"/>

            <ImageView
                android:id="@+id/webSiteImageView"
                android:layout_weight="1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/website_9703"/>

        </LinearLayout>

        <TextView
            android:id="@+id/group_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="@dimen/margin_top_24dp"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/groups_in_this_place"
            android:textColor="@color/post_color"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/placeDetailContainer" />

        <TextView
            android:id="@+id/group_name_tv"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/roboto_bold"
            android:text="@{data.dominantGroup.name}"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintBottom_toBottomOf="@+id/groupImage2"
            app:layout_constraintStart_toEndOf="@+id/groupImage2"
            app:layout_constraintTop_toTopOf="@+id/groupImage2" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="@+id/group_name_tv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/group_name_tv"
            app:layout_constraintTop_toTopOf="@+id/group_name_tv">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/group_images_rv"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:maxWidth="175dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:listitem="@layout/each_group_icon_item" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/progressCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/groupImage2">

            <com.orbis.orbis.utils.customViews.ColoredProgressBar
                android:id="@+id/progress_horizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/group_shadow_circle"
                app:sw_radius="7dp" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/feed_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/feed"
            android:textColor="@color/post_color"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/progressCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>