<?xml version="1.0" encoding="utf-8"?>

<androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fitsSystemWindows="true"
    android:gravity="center"
    app:contentInsetEnd="@dimen/_0dp"
    app:contentInsetStart="@dimen/_0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/top_cl"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/back_arrow_iv"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="@dimen/margin_top_16dp"
                android:layout_marginTop="@dimen/margin_top_24dp"
                android:contentDescription="@string/image_description"
                android:src="@drawable/ic_back_arrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/user_icon_iv"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:contentDescription="@string/image_description"
                android:layout_marginTop="@dimen/margin_top_24dp"
                android:src="@drawable/image_test2"
                app:layout_constraintStart_toEndOf="@+id/back_arrow_iv"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:fontFamily="@font/roboto_bold"
                android:text="Joana Klabin"
                android:layout_marginTop="26dp"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_16sp"
                app:layout_constraintStart_toEndOf="@+id/user_icon_iv"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/online_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_marginStart="@dimen/margin_start_16dp"
                android:fontFamily="@font/roboto_bold"
                android:text="Online a 11 min"
                android:textColor="@color/hint_color"
                android:textSize="@dimen/text_size_11sp"
                app:layout_constraintStart_toEndOf="@+id/user_icon_iv"
                app:layout_constraintTop_toBottomOf="@+id/title_tv" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/view"
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/line_color"
            android:layout_marginTop="@dimen/margin_top_24dp"
            app:layout_constraintTop_toBottomOf="@+id/top_cl" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.Toolbar>