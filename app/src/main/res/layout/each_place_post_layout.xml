<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_id"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/post_cl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/user_cl"
            android:layout_width="@dimen/_0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="@dimen/margin_bottom_24dp"
            android:layout_marginEnd="@dimen/margin_end_32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <com.orbis.orbis.utils.customViews.RoundLinerLayoutNormal
                android:id="@+id/user_shadow_circle"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:rll_elevation="@dimen/elevation_6dp"
                app:rll_shadow_bkg_color="@color/white"
                app:rll_shadow_color="@color/shadowColor"
                app:rll_shadow_radius="25dp">

                <ImageView
                    android:id="@+id/user_icon_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_border"
                    android:contentDescription="@string/image_description"
                    android:padding="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </com.orbis.orbis.utils.customViews.RoundLinerLayoutNormal>

            <TextView
                android:id="@+id/user_name_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_12dp"
                android:fontFamily="@font/roboto_bold"
                android:text="Maria Luiza"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_16sp"
                app:layout_constraintBottom_toBottomOf="@+id/user_shadow_circle"
                app:layout_constraintStart_toEndOf="@id/user_shadow_circle"
                app:layout_constraintTop_toTopOf="@+id/user_shadow_circle" />

            <TextView
                android:id="@+id/date_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_regular"
                android:text="25/04 as 12:12"
                android:textColor="@color/hint_color"
                android:textSize="@dimen/text_size_12sp"
                app:layout_constraintBottom_toBottomOf="@+id/user_name_tv"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/user_name_tv" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/post_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_bottom_24dp"
            android:fontFamily="@font/roboto_regular"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:text="Lorem ipsum dolor sit amet, consetetur sadipscingStet  dolor Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor"
            android:textColor="@color/post_color"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintEnd_toEndOf="@id/user_cl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/user_cl" />

        <ImageView
            android:id="@+id/post_iv"
            android:layout_width="match_parent"
            android:layout_height="256dp"
            android:layout_marginTop="@dimen/margin_bottom_24dp"
            android:scaleType="fitXY"
            android:src="@drawable/post_image"
            app:layout_constraintTop_toBottomOf="@id/post_tv" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/comment_cl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_start_16dp"
        android:layout_marginTop="@dimen/margin_top_24dp"
        android:layout_marginEnd="@dimen/margin_end_16dp"
        app:layout_constraintTop_toBottomOf="@+id/post_cl">

        <ImageView
            android:id="@+id/likes_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic__heart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/likes_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_8dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="247"
            android:textColor="@color/likes_color"
            android:textSize="@dimen/text_size_12sp"
            app:layout_constraintBottom_toBottomOf="@id/likes_iv"
            app:layout_constraintStart_toEndOf="@id/likes_iv"
            app:layout_constraintTop_toTopOf="@id/likes_iv" />

        <ImageView
            android:id="@+id/comments_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_32dp"
            android:src="@drawable/ic_comment"
            app:layout_constraintBottom_toBottomOf="@+id/likes_iv"
            app:layout_constraintStart_toEndOf="@id/likes_tv"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/comments_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_8dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="57"
            android:textColor="@color/likes_color"
            android:textSize="@dimen/text_size_12sp"
            app:layout_constraintBottom_toBottomOf="@id/likes_iv"
            app:layout_constraintStart_toEndOf="@id/comments_iv"
            app:layout_constraintTop_toTopOf="@id/likes_iv" />

        <ImageView
            android:id="@+id/share_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_32dp"
            android:src="@drawable/ic_reload"
            app:layout_constraintBottom_toBottomOf="@+id/likes_iv"
            app:layout_constraintStart_toEndOf="@id/comments_tv"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/share_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_8dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:text="33"
            android:textColor="@color/likes_color"
            android:textSize="@dimen/text_size_12sp"
            app:layout_constraintBottom_toBottomOf="@id/likes_iv"
            app:layout_constraintStart_toEndOf="@id/share_iv"
            app:layout_constraintTop_toTopOf="@id/likes_iv" />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="1.5dp"
        android:layout_marginTop="@dimen/margin_bottom_24dp"
        android:background="@color/line_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/comment_cl" />

</androidx.constraintlayout.widget.ConstraintLayout>