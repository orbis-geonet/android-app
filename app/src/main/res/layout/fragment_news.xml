<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/news_rv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/padding_bottom_90dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/no_news_iv"
        android:layout_width="match_parent"
        android:layout_height="167dp"
        android:layout_marginTop="@dimen/margin_top_52dp"
        android:src="@drawable/ic_connect_instagram"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="@string/image_description"
        android:visibility="gone"
        tools:visibility="visible"
       />

    <TextView
        android:id="@+id/no_posts_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_top_24dp"
        android:layout_marginStart="@dimen/margin_start_52dp"
        android:layout_marginEnd="@dimen/margin_end_52dp"
        android:fontFamily="@font/roboto_regular"
        android:textSize="@dimen/text_size_14sp"
        android:gravity="center"
        android:text="@string/no_news"
        app:layout_constraintTop_toBottomOf="@+id/no_news_iv"
        android:visibility="gone"
        tools:visibility="visible"/>
</androidx.constraintlayout.widget.ConstraintLayout>