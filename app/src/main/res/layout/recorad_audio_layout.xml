<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/mic_iv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_mic"
        app:layout_constraintBottom_toBottomOf="@+id/voice_signal_iv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ImageView
        android:id="@+id/voice_signal_iv"
        android:layout_width="@dimen/_0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_start_8dp"
        android:layout_marginEnd="@dimen/margin_12dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_voice_signal"
        app:layout_constraintEnd_toStartOf="@id/close_audio_iv"
        app:layout_constraintStart_toEndOf="@id/mic_iv"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/voice_length_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
       android:layout_marginTop="@dimen/margin_top_8dp"
        android:fontFamily="@font/roboto_bold"
        android:lineSpacingExtra="10sp"
        android:text="0:48"
        android:textColor="@color/hint_color"
        android:textSize="@dimen/text_size_12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/voice_signal_iv"
        app:layout_constraintTop_toBottomOf="@id/voice_signal_iv" />

    <ImageView
        android:id="@+id/close_audio_iv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_close"
        app:layout_constraintBottom_toBottomOf="@id/mic_iv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/mic_iv" />
</androidx.constraintlayout.widget.ConstraintLayout>