<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

        <import type="android.view.View" />

        <variable
            name="loading"
            type="Boolean" />
    </data>
<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center|top"
        android:background="@drawable/bottom_sheet_bg">

        <View
            android:id="@+id/view"
            android:layout_width="130dp"
            android:layout_height="2dp"
            android:layout_marginTop="@dimen/radius_10dp"
            android:background="@color/black"
            android:layout_gravity="center"/>

        <include
            android:id="@+id/toolbar"
            layout="@layout/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_top_8dp" />

        <TextView
            android:id="@+id/place_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_top_24dp"
            android:lineSpacingExtra="5sp"
            android:text="@string/textView_how_many_stars"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:textSize="18sp"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/confirm_iv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/map_cl" />


        <com.willy.ratingbar.ScaleRatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:srb_rating="0"
            app:srb_clearRatingEnabled="true"
            app:srb_clickable="true"
            app:srb_isIndicator="false"
            app:srb_drawableEmpty="@drawable/icon_awesome_star_empty"
            app:srb_drawableFilled="@drawable/icon_awesome_star_fill"
            app:srb_minimumStars="1"
            app:srb_numStars="5"
            app:srb_scrollable="true"
            app:srb_starHeight="46dp"
            app:srb_starWidth="46dp"
            app:srb_stepSize="1" />

        <Button
            android:id="@+id/updateButton"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="@dimen/margin_bottom_24dp"
            android:background="@drawable/black_btn"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/button_rate"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:enabled="@{!loading}"
            android:textSize="@dimen/text_size_16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/black"
            android:layout_marginBottom="@dimen/margin_bottom_24dp"/>
    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/loader12"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:elevation="8dp"
        android:visibility="@{loading ? View.VISIBLE : View.GONE}"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_fileName="loader.json"
        app:lottie_loop="true" />

</FrameLayout>
</layout>