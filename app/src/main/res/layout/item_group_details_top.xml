<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.orbis.orbis.models.group.GroupDetails" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_id"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginTop="16dp"
            android:background="@color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/noItem"
            tools:layout_editor_absoluteX="8dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/post_cl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.viewpager.widget.ViewPager
                    android:id="@+id/check_in_viewpager"
                    android:layout_width="0dp"
                    android:layout_height="350dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </androidx.viewpager.widget.ViewPager>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="50dp"
                    android:background="@null"
                    app:layout_constraintBottom_toBottomOf="@+id/check_in_viewpager"
                    app:tabBackground="@drawable/tab_dots_layout_selector"
                    app:tabGravity="center"
                    app:tabIndicator="@null"
                    app:tabIndicatorColor="@android:color/transparent"
                    app:tabIndicatorHeight="0dp"
                    app:tabMaxWidth="20dp"
                    app:tabMode="fixed"
                    app:tabPadding="8dp"
                    app:tabRippleColor="@null"
                    app:tabSelectedTextColor="@color/black"
                    app:tabTextAppearance="@style/tabsStyle"
                    tools:layout_editor_absoluteX="56dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/view"
                android:layout_width="0dp"
                android:layout_height="1.5dp"
                android:background="@color/line_color"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/noItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:elevation="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView5">

            <ImageView
                android:id="@+id/no_photo_iv3"
                android:layout_width="match_parent"
                android:layout_height="167dp"
                android:layout_marginTop="@dimen/margin_top_52dp"
                android:contentDescription="@string/image_description"
                android:src="@drawable/ic_connect_instagram"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/no_photo_tv3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_start_52dp"
                android:layout_marginTop="@dimen/margin_top_24dp"
                android:layout_marginEnd="@dimen/margin_end_52dp"
                android:fontFamily="@font/roboto_regular"
                android:gravity="center"
                android:text="@string/no_post_has_been_uploaded_to_this_group_yet"
                android:textSize="@dimen/text_size_14sp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@+id/no_photo_iv" />

        </LinearLayout>

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/feed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrier" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/shadow_circle"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_user"
            app:civ_border_color="@{data.strokeColorHex}"
            app:civ_border_width="3dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/group_name_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/roboto_bold"
            android:maxLines="2"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_16sp"
            app:layout_constraintEnd_toStartOf="@+id/group_menu_iv"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/shadow_circle"
            app:layout_constraintTop_toTopOf="@+id/shadow_circle" />

        <ImageView
            android:id="@+id/group_menu_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:src="@drawable/ic_menu"
            app:layout_constraintBottom_toBottomOf="@id/group_name_tv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/group_name_tv" />

        <TextView
            android:id="@+id/places_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="2dp"
            android:fontFamily="@font/roboto_bold"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_16sp"
            app:layout_constraintBottom_toTopOf="@+id/places_title"
            app:layout_constraintEnd_toEndOf="@id/places_title"
            app:layout_constraintStart_toStartOf="@id/places_title"
            app:layout_constraintTop_toBottomOf="@+id/group_name_tv"/>

        <TextView
            android:id="@+id/places_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:text="@string/places"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_12sp"
            app:layout_constraintTop_toBottomOf="@+id/places_tv"
            app:layout_constraintStart_toStartOf="@id/group_name_tv" />

        <TextView
            android:id="@+id/members_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_bold"
            android:gravity="center"
            android:text="3.838"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_16sp"
            app:layout_constraintBottom_toBottomOf="@+id/places_tv"
            app:layout_constraintEnd_toEndOf="@id/members_title"
            app:layout_constraintStart_toStartOf="@id/members_title"
            app:layout_constraintTop_toTopOf="@+id/places_tv" />

        <TextView
            android:id="@+id/members_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:text="@string/members"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_12sp"
            app:layout_constraintTop_toBottomOf="@+id/members_tv"
            app:layout_constraintEnd_toStartOf="@+id/status_tv"
            app:layout_constraintStart_toEndOf="@id/places_title" />

        <ImageView
            android:id="@+id/status_iv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_fire"
            app:layout_constraintBottom_toBottomOf="@+id/members_tv"
            app:layout_constraintEnd_toEndOf="@id/status_tv"
            app:layout_constraintStart_toStartOf="@+id/status_tv" />

        <TextView
            android:id="@+id/status_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:text="@string/status"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_12sp"
            app:layout_constraintTop_toBottomOf="@+id/members_tv"
            app:layout_constraintEnd_toEndOf="@+id/group_name_tv" />

        <com.orbis.orbis.utils.customViews.ViewMoreTextView
            android:id="@+id/group_desc_tv"
            android:layout_width="@dimen/_0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_start_16dp"
            android:layout_marginTop="16dp"
            android:textColor="@color/hint_color"
            android:textSize="16sp"
            android:textStyle="normal"
            android:visibility="visible"
            app:fontFamily="@font/roboto_regular"
            app:layout_constraintEnd_toEndOf="@id/group_menu_iv"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/members_title" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/subscriptionButtons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/group_desc_tv">

            <Button
                android:id="@+id/create_subscription_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/border_black_btn"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/create_subscription"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_12sp"
                android:visibility="gone"
                app:backgroundTint="@null"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/subscription_activity_btn"
                app:layout_constraintStart_toStartOf="parent"
                tools:visibility="visible" />

            <Button
                android:id="@+id/subscription_activity_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="16dp"
                android:background="@drawable/border_black_btn"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/activity"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_12sp"
                android:visibility="gone"
                app:backgroundTint="@null"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/create_subscription_btn"
                tools:visibility="visible" />

            <Button
                android:id="@+id/subscription_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="16dp"
                android:background="@drawable/black_btn"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/subscription"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_12sp"
                android:visibility="gone"
                app:backgroundTint="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/create_subscription_btn"
                tools:visibility="visible" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="subscriptionButtons_container" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>