<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="16dp"
    android:background="@drawable/bg_group_popup">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="214dp"
        android:maxWidth="280dp"
        android:text="The group beer"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#222222" />

    <TextView
        android:id="@+id/groupDescription"
        android:layout_width="wrap_content"
        android:maxWidth="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="This is a group for beer lovers to share and hang out."
        android:textSize="14sp"
        android:textColor="#9E9E9E"
        android:lineSpacingExtra="2dp"
        android:ellipsize="end"
        android:maxLines="3" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/avatarGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/avatar1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_user"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle" />

            <ImageView
                android:id="@+id/avatar2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="-10dp"
                android:src="@drawable/ic_user"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle" />

            <ImageView
                android:id="@+id/avatar3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="-10dp"
                android:src="@drawable/ic_user"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle" />
        </LinearLayout>

        <TextView
            android:id="@+id/members"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="0dp"
            android:layout_weight="1"
            android:text="125 Members"
            android:textSize="16sp"
            android:textColor="#777777"
            android:ellipsize="end"
            android:maxLines="1" />

    </LinearLayout>
</LinearLayout>