<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/line_opacity2"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/gradient_blur_bg"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/photo_item_iv"
        android:layout_width="80dp"
        android:layout_height="70dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="@dimen/margin_start_16dp"
        android:contentDescription="@string/image_description"
        android:src="@drawable/ic_logo_tipography_only"
        app:layout_constraintBottom_toBottomOf="@+id/login_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/login_btn" />
    <Button
        android:id="@+id/login_btn"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="@dimen/login_btn_width"
        android:layout_height="@dimen/login_btn_height"
        android:layout_marginTop="@dimen/margin_top_32dp"
        android:layout_marginEnd="@dimen/margin_end_16dp"
        android:background="@drawable/black_btn"
        android:fontFamily="@font/roboto_bold"
        android:textAllCaps="false"
        android:padding="4dp"
        android:text="@string/login"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/logo_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_start_16dp"
        android:fontFamily="@font/arciform"
        android:letterSpacing="0.2"
        android:text="ORBIS"
        tools:text="ORBIS"
        android:textStyle="normal"
        android:lineSpacingExtra="5sp"
        android:textColor="@color/black"
        android:visibility="invisible"
        android:textSize="@dimen/text_size_24sp"
        app:layout_constraintBottom_toBottomOf="@+id/login_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/login_btn" />



    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/logo_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_bottom_24dp"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_logotipo"
        app:borderWidth="@dimen/_0dp"
        app:fabCustomSize="@dimen/logo_fab_size"
        app:elevation="@dimen/elevation_5dp"
        app:layout_constraintBottom_toBottomOf="@+id/map"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:maxImageSize="@dimen/logo_fab_icon_size" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/groups_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_end_32dp"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_groups"
        app:borderWidth="@dimen/_0dp"
        app:fabCustomSize="@dimen/fab_size"
        app:elevation="@dimen/elevation_5dp"
        app:layout_constraintBottom_toBottomOf="@+id/logo_fab"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/logo_fab"
        app:maxImageSize="@dimen/fab_icon_size" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/news_feed_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_start_32dp"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_news"
        app:borderWidth="@dimen/_0dp"
        app:fabCustomSize="@dimen/fab_size"
        app:elevation="@dimen/elevation_5dp"
        app:layout_constraintBottom_toBottomOf="@+id/logo_fab"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/logo_fab"
        app:maxImageSize="@dimen/fab_icon_size" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/my_location_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/floatingactionbuttondescription"
        android:src="@drawable/ic_my_location"
        app:borderWidth="@dimen/_0dp"
        android:alpha="0.7"
        app:elevation="@dimen/elevation_5dp"
        android:layout_marginBottom="@dimen/margin_bottom_8dp"
        app:fabCustomSize="@dimen/fab_location_size"
        app:layout_constraintBottom_toTopOf="@+id/logo_fab"
        app:layout_constraintEnd_toEndOf="@+id/logo_fab"
        app:layout_constraintStart_toStartOf="@+id/logo_fab"
        app:maxImageSize="@dimen/fab_location_icon_size" />

    <LinearLayout
        android:id="@+id/line_opacity"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_bg"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.orbis.orbis.utils.customViews.VerticalSeekBar
        android:id="@+id/right_seekbar"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:max="200"
        android:progress="100"
        app:layout_constraintEnd_toEndOf="parent"
        app:thumb="@drawable/ic_right_thumb" />

    <com.orbis.orbis.utils.customViews.VerticalSeekBar
        android:id="@+id/left_seekbar"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:max="200"
        android:progress="100"
        app:layout_constraintStart_toStartOf="parent"
        app:thumb="@drawable/ic_left_thumb" />


</androidx.constraintlayout.widget.ConstraintLayout>
